# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# NCBI / PubMed — https://www.ncbi.nlm.nih.gov/account/
# A key is optional but increases the rate limit from 3 to 10 requests/sec
NCBI_API_KEY=your_ncbi_api_key
NCBI_EMAIL=your@email.com

# Qdrant Cloud — https://cloud.qdrant.io
QDRANT_URL=https://your-cluster-id.region.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# LangSmith tracing (optional) — https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=weightloss-rag-pubmed

# Groq (optional — not used by default)
GROQ_API_KEY=
